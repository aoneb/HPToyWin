<Window x:Class="HPToy.Win.Dialogs.DeviceDiscoveryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="420" Width="520"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/hptoy.png">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="HintText" Grid.Row="0" Margin="0,0,0,8"/>
        <ListBox x:Name="DeviceList" Grid.Row="1" DisplayMemberPath="DisplayName"/>
        <TextBlock x:Name="StatusText" Grid.Row="2" Margin="0,8,0,8" Foreground="Gray"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ScanBtn" Width="88" Margin="0,0,8,0" Click="Scan_Click"/>
            <Button x:Name="ConnectBtn" Width="88" Margin="0,0,8,0" Click="Connect_Click"/>
            <Button x:Name="CloseBtn" Width="88" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
