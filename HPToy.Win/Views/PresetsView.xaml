<UserControl x:Class="HPToy.Win.Views.PresetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ListBox x:Name="PresetList" Grid.Row="0" DisplayMemberPath="Name" SelectionChanged="PresetList_SelectionChanged"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
            <Button x:Name="ApplyBtn" Width="88" Margin="4" Click="Apply_Click"/>
            <Button x:Name="DeleteBtn" Width="88" Margin="4" Click="Delete_Click"/>
            <Button x:Name="RenameBtn" Width="88" Margin="4" Click="Rename_Click"/>
            <Button x:Name="ImportBtn" Width="88" Margin="4" Click="Import_Click"/>
            <Button x:Name="ExportBtn" Width="88" Margin="4" Click="Export_Click"/>
            <Button x:Name="RefreshBtn" Width="88" Margin="4" Click="RefreshList_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
