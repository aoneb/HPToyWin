<UserControl x:Class="HPToy.Win.Views.MainControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16" MaxWidth="520">
            <TextBlock x:Name="MasterVolumeLabel" FontSize="16" Margin="0,0,0,4"/>
            <DockPanel Margin="0,0,0,16">
                <TextBlock x:Name="VolumeLabel" Width="80" VerticalAlignment="Center" FontSize="18"
                           MouseLeftButtonUp="VolumeLabel_Click" Cursor="Hand"/>
                <Slider x:Name="VolumeSlider" Minimum="0" Maximum="100" TickFrequency="1"
                        ValueChanged="VolumeSlider_ValueChanged"
                        PreviewMouseUp="VolumeSlider_Commit"
                        KeyUp="VolumeSlider_Commit"/>
            </DockPanel>

            <UniformGrid Columns="2" Margin="0,0,0,16">
                <Button x:Name="NavBassBtn" Margin="4" Padding="12" Click="NavBass_Click"/>
                <Button x:Name="NavTrebleBtn" Margin="4" Padding="12" Click="NavTreble_Click"/>
                <Button x:Name="NavLoudnessBtn" Margin="4" Padding="12" Click="NavLoudness_Click"/>
                <Button x:Name="NavFiltersBtn" Margin="4" Padding="12" Click="NavFilters_Click"/>
                <Button x:Name="NavCompressorBtn" Margin="4" Padding="12" Click="NavCompressor_Click"/>
                <Button x:Name="NavPresetsBtn" Margin="4" Padding="12" Click="NavPresets_Click"/>
            </UniformGrid>

            <TextBlock x:Name="ActivePresetLabel" Margin="0,8,0,4"/>
            <TextBlock x:Name="PresetNameText" FontSize="14" Margin="0,0,0,8"/>
            <Button x:Name="SavePresetBtn" Padding="10" Click="SavePreset_Click"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
