<UserControl x:Class="HPToy.Win.Views.BassView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="16" MaxWidth="520">
        <TextBlock x:Name="TitleLabel" FontSize="16" Margin="0,0,0,8"/>
        <DockPanel>
            <TextBlock x:Name="BassLabel" Width="80" VerticalAlignment="Center" FontSize="18"
                       MouseLeftButtonUp="BassLabel_Click" Cursor="Hand"/>
            <Slider x:Name="BassSlider" Minimum="0" Maximum="100" ValueChanged="BassSlider_ValueChanged"/>
        </DockPanel>
    </StackPanel>
</UserControl>
