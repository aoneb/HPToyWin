<UserControl x:Class="HPToy.Win.Views.LoudnessView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="16" MaxWidth="520">
        <TextBlock x:Name="GainTitleLabel" FontSize="16" Margin="0,0,0,8"/>
        <DockPanel Margin="0,0,0,16">
            <TextBlock x:Name="GainLabel" Width="80" VerticalAlignment="Center"/>
            <Slider x:Name="GainSlider" Minimum="0" Maximum="200" ValueChanged="GainSlider_ValueChanged"/>
        </DockPanel>
        <TextBlock x:Name="FreqTitleLabel" Margin="0,0,0,8"/>
        <DockPanel>
            <TextBlock x:Name="FreqLabel" Width="80" VerticalAlignment="Center"/>
            <Slider x:Name="FreqSlider" Minimum="30" Maximum="200" ValueChanged="FreqSlider_ValueChanged"/>
        </DockPanel>
    </StackPanel>
</UserControl>
