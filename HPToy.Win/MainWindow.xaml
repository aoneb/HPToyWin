<Window x:Class="HPToy.Win.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:HPToy.Win.Views"
        Height="640" Width="900"
        MinHeight="480" MinWidth="720"
        Icon="/Assets/hptoy.png">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D2D30" Padding="10">
            <DockPanel>
                <Button x:Name="ConnectButton" Width="88" Margin="0,0,12,0"
                        DockPanel.Dock="Left" Click="Connect_Click"/>
                <ComboBox x:Name="LanguageCombo" Width="96" Margin="0,0,12,0"
                          DockPanel.Dock="Right" SelectionChanged="Language_Changed"/>
                <Ellipse x:Name="ClipIndicator" Width="14" Height="14" Fill="#555" Margin="0,0,8,0"
                         DockPanel.Dock="Right" VerticalAlignment="Center"/>
                <TextBlock x:Name="DeviceNameText" Foreground="#FF9E40" VerticalAlignment="Center"
                           DockPanel.Dock="Right" Margin="0,0,12,0"/>
                <TextBlock x:Name="StatusText" Foreground="White" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <TabControl x:Name="MainTabs" Grid.Row="1" Margin="8">
            <TabItem Tag="Main">
                <views:MainControlView x:Name="MainView"/>
            </TabItem>
            <TabItem Tag="Bass">
                <views:BassView x:Name="BassView"/>
            </TabItem>
            <TabItem Tag="Treble">
                <views:TrebleView x:Name="TrebleView"/>
            </TabItem>
            <TabItem Tag="Loudness">
                <views:LoudnessView x:Name="LoudnessView"/>
            </TabItem>
            <TabItem Tag="Filters">
                <views:FiltersView x:Name="FiltersView"/>
            </TabItem>
            <TabItem Tag="Compressor">
                <views:CompressorView x:Name="CompressorView"/>
            </TabItem>
            <TabItem Tag="Presets">
                <views:PresetsView x:Name="PresetsView"/>
            </TabItem>
            <TabItem Tag="Options">
                <views:OptionsView x:Name="OptionsView"/>
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock x:Name="LogText"/>
            </StatusBarItem>
            <StatusBarItem>
                <ProgressBar x:Name="WriteProgressBar" Width="120" Height="14" Visibility="Collapsed"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
